std_msgs/Header header //언제 publish된 상태

bool engaged //최종 상위 상태
uint8 state //engaged를 enum으로 풀어쓴 값
uint8 phase //ENGAGED 내부 하위 구간
(0 = NONE : DISENGAGED일 때
 1 = ENTRY : ENGAGED 직후 권한 램프업 구간
 2 = STEADY : ENTRY가 끝난 정상 전달 구간)

uint32 reason_bits //최종 state 결정에 사용된 통합 reason(최종 판정 로직에서 유효했던 사유)
uint8 reason_primary //우선순위 기반 파생값(reason_bits 중에서도 최종 판정을 대표하는 1순위 사유)
